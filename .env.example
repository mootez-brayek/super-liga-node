PORT=3000
# Local dev: localhost or your MySQL host.
# Hostinger: set this to the MySQL host from hPanel, usually localhost.
DB_HOST=localhost
DB_PORT=3306
# Use one pair only, or make both identical.
# Replace the values with the exact Hostinger MySQL database name and user.
DB_USERNAME=your_db_user
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
DB_NAME=your_db_name
JWT_SECRET=change_me_to_a_long_secret
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123
SUPERADMIN_FIRSTNAME=Super
SUPERADMIN_LASTNAME=Admin
# Comma-separated list allowed.
CORS_ORIGIN=http://localhost:4200
